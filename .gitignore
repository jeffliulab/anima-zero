# ============================================================
# anima — ANIMA Open v1 .gitignore
# (Python + LLM tooling, open-source cognitive framework)
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
sdist/
wheels/
share/python-wheels/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version
Pipfile.lock
poetry.lock
uv.lock

# Test / type-check / coverage
.pytest_cache/
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/
.tox/
.nox/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover
.hypothesis/

# ------------------------------------------------------------
# Jupyter / notebooks
# ------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ------------------------------------------------------------
# Secrets / API keys (CRITICAL — LLM API keys must never leak)
# ------------------------------------------------------------
.env
.env.*
!.env.example
!.env.template
*.key
*.pem
*_secret*
*_credentials*
secrets/
credentials/
api_keys.json
config/local.yaml
config/local.*.yaml

# ------------------------------------------------------------
# Models / weights / LLM artifacts
# ------------------------------------------------------------
*.pt
*.pth
*.onnx
*.engine
*.trt
*.bin
*.safetensors
*.gguf
*.ggml
*.ckpt
*.h5
*.pkl
*.npy
*.npz
weights/
checkpoints/
models/pretrained/
models/cache/
.cache/
# HuggingFace cache (if accidentally placed here)
huggingface/
transformers_cache/

# ------------------------------------------------------------
# LLM / agent runtime artifacts
# ------------------------------------------------------------
# Conversation traces, prompt logs, eval outputs
traces/
runs/
outputs/
eval_results/
prompt_logs/
*.trace.json
*.run.json

# Vector stores / embeddings caches
*.faiss
*.chroma
chroma_db/
vector_store/
embeddings_cache/

# ------------------------------------------------------------
# Datasets / generated data
# ------------------------------------------------------------
data/raw/
data/processed/
data/interim/
datasets/
*.lmdb
*.tfrecord
*.parquet
*.feather
# Allow small fixture data — uncomment patterns as needed:
# !tests/fixtures/**/*.json
# !data/sample/**

# ------------------------------------------------------------
# Logs / temporary
# ------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.swp
*.swo
*~

# ------------------------------------------------------------
# Documentation build
# ------------------------------------------------------------
docs/_build/
docs/build/
site/
.docusaurus/

# ------------------------------------------------------------
# IDE / editor
# ------------------------------------------------------------
.vscode/
!.vscode/settings.json.example
.idea/
*.iml
*.code-workspace
.cursorrules
.aider*

# Claude Code local settings (if any leak in)
.claude/

# ------------------------------------------------------------
# OS
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Agent working notes (local only — not part of the open-source repo)
CLAUDE.md
node_modules/
.next/

# 本地记忆(会话记录 + 图片;单用户,不入库)
memory/

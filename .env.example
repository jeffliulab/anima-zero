# ============================================================
# ANIMA Zero v0.1 —— 大脑(LLM)配置模板
# ------------------------------------------------------------
# 用法:复制成 .env(同目录),按需填写,再启动后端即可。
#   cp .env.example .env
# 只需配置你实际要用的那个大脑,其它留空;启动后端会自动读取 .env。
# 「用哪个大脑」在网页对话框里下拉选择,不在这里设;这里只放各大脑要的 key / 地址。
# 大脑的版本号写在 src/llm/factory.py 的登记表里(想换版本改那里)。
# ⚠️ .env 已在 .gitignore 中,不会入库;本模板(.env.example)可入库。
# ============================================================


# ===== A. 在线大脑(需要 API key,联网)=====

# --- Anthropic / Claude ---  网页里选 opus / haiku 时用
#   opus  = Claude Opus 4.8(最强;输入 $5 / 输出 $25 每百万 token)
#   haiku = Claude Haiku 4.5(便宜;$1 / $5)
# 两个 Claude 大脑共用下面这一个 key。
ANTHROPIC_API_KEY=

# --- OpenAI / GPT ---  网页里选 gpt-5.5 / gpt-4.1-nano 时用
#   gpt-5.5      = GPT-5.5(旗舰;$5 / $30)
#   gpt-4.1-nano = GPT-4.1-nano(极便宜,适合调试;$0.10 / $0.40)
# 两个 GPT 大脑共用下面这一个 key。
OPENAI_API_KEY=


# ===== B. 本地大脑(经 Ollama,免费、离线)=====
# 前置:装好 Ollama 并起服务(ollama serve),再 pull 下面的模型。

# Ollama 的 OpenAI 兼容地址(默认本机 11434;换端口/远程改这里)
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- qwen3-vl ---  网页里选 qwen3-vl 时用(目前唯一的本地大脑)
#   先 `ollama pull qwen3-vl:8b`;若实际 tag 不同,改下面这行
#   选 Qwen3-VL 是因为它在 Ollama 上视觉 + 工具调用最均衡;想加别的本地/在线大脑,
#   见 src/llm/README.md《如何给 ANIMA 增加一个语言大脑》。
ANIMA_QWEN3VL_MODEL=qwen3-vl:8b


# ===== C. 世界地址(独立运行的「世界」程序)=====
# 世界(sim-desk 桌面 / sim-chess 棋具 / 以后 MuJoCo / 真机)是独立进程,anima 按 URL 连它。
# 世界清单:name=url,多个用逗号隔开。
# ⚠️ 加一个世界 = 往这一行【追加】一项,**绝不要替换掉已有的世界**
#    (2026-06-28 踩过坑:加 sim-chess 时只写了 sim-chess,把 sim-desk 挤没了 → T0 回归)。
ANIMA_WORLDS=sim-desk=http://localhost:8100,sim-chess=http://localhost:8102
# 启动默认绑哪个世界(留空 = 绑清单里第一个)
DEFAULT_WORLD=sim-desk
# 没设 ANIMA_WORLDS 时的回退默认地址(代码默认清单已含这两个世界,这里只在你想改地址时用)。
SIM_DESK_URL=http://localhost:8100
SIM_CHESS_URL=http://localhost:8102


# ===== D. 跨域(CORS)=====
# 允许哪些网页源访问后端 / 世界,多个用逗号隔开;设成 * 全开(demo 方便,生产别全开)。
ANIMA_CORS_ORIGINS=http://localhost:3000


# ===== E. 可选调参(都有默认值,不填即用默认;改这些才需要写) =====
# -- 编排器 / 上下文 --
# ANIMA_MAX_STEPS=8                 # ReAct 主循环最多转几轮
# ANIMA_CONTEXT_BUDGET=6000         # 上下文滑窗 token 预算
# -- 世界客户端 / 会话 / AWI --
# ANIMA_WORLD_TIMEOUT=30            # 普通调用世界的超时(秒)
# ANIMA_WORLD_PROBE_TIMEOUT=1.5     # 探在线的短超时
# ANIMA_AWI_POLL_INTERVAL_S=0.25    # AWI 流量 SSE 查新间隔
# -- 模型 id(单一来源,换模型版本改这里) --
# ANIMA_CLAUDE_OPUS_MODEL=claude-opus-4-8
# ANIMA_OPENAI_GPT_MODEL=gpt-5.5
# ANIMA_QWEN3VL_MODEL=qwen3-vl:8b
# -- 对弈行为树 / 对局 --
# ANIMA_GAME_TICK_S=1.0             # 每拍周期(秒)
# ANIMA_GAME_MAX_FAIL=5             # 发命令(act)连续失败上限
# ANIMA_GAME_PERCEIVE_MAX_FAIL=5    # 感知(世界异常)失败上限(与 act 分开)
# ANIMA_GAME_WORLD_TIMEOUT=2.5      # 对弈专用世界 client 短超时(协作式取消够快的关键)
# ANIMA_GAME_CANCEL_JOIN_S=3.0      # 停旧对弈线程的 join 上限
# ANIMA_GAME_RESIGN_EVAL=-900       # 我方视角形势分(厘兵)低于此→倾向认输
# ANIMA_GAME_RESIGN_CONFIRM=3       # 须连续这么多拍都极差才认输(避免兑子瞬间误判)
# -- 视觉(置信度/多帧确认) --
# ANIMA_VISION_AMBIGUITY_RATIO=0.7  # Lowe 比值:最近/次近 SAD 超此→该格"看不清"
# ANIMA_VISION_CONFIRM_FRAMES=2     # 多帧确认:候选局面连续几帧一致才采信
# -- 象棋引擎(ANIMA 自己的脑子) --
# ANIMA_CHESS_DEPTH=3
# ANIMA_CHESS_TIME=1.5
# -- 路径(默认从仓库结构派生;移动了仓库再设) --
# ANIMA_CHESS_ENGINE_PATH=/abs/path/to/3-anima-chess-engine/chess/engine.py
# ANIMA_BOARD_FONT=/abs/path/to/DejaVuSans-Bold.ttf
# -- sim-chess 世界端(世界独立进程,自己的 env) --
# SIMCHESS_VERSION=0.1
# SIMCHESS_BOT_DEPTH=2
# SIMCHESS_BOT_TIME=0.5
# SIMCHESS_ENGINE_PATH=/abs/path/to/3-anima-chess-engine/chess/engine.py


# ============================================================
# ⚠️ 提醒:本地视觉模型经 Ollama 的「工具调用(function calling)」支持参差不齐,
#    是真脑闭环最可能翻车的地方。建议先用云端(GPT-4.1-nano / Claude)把闭环
#    验证通,再换本地。
# ============================================================
